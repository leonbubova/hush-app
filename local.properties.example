# Local configuration (copy to local.properties and fill in your values)
# This file is gitignored — never commit real credentials

# Release signing (required for release builds only)
RELEASE_STORE_FILE=/path/to/your-keystore.jks
RELEASE_STORE_PASSWORD=your-keystore-password
RELEASE_KEY_ALIAS=your-key-alias
RELEASE_KEY_PASSWORD=your-key-password

# Test API keys (optional, for instrumented E2E tests)
# Tests skip gracefully if these are not set
TEST_VOXTRAL_KEY=your-voxtral-api-key
# TEST_OPENAI_KEY=your-openai-api-key
# TEST_GROQ_KEY=your-groq-api-key
